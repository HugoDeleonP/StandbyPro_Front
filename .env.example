# URL base da API Spring Boot (standbypro-backend). So usada no servidor
# (Server Components/Server Actions) - nunca exposta ao navegador.
BACKEND_URL=http://localhost:8080

# Opcional: backend alternativo, usado automaticamente se BACKEND_URL nao
# responder (rede/timeout de 8s) - nao entra em jogo se a API responder com
# um erro HTTP normal (401/403/422/etc.), so em caso de indisponibilidade.
# So faz sentido apontar para algo que o processo do frontend realmente
# alcance: em dev local, o backend rodando na mesma maquina (localhost);
# num frontend ja implantado (Render), teria que ser outro endereco publico
# (ex.: um tunel para o backend local) - "localhost" dentro do container do
# Render nao serve de nada.
# BACKEND_URL_FALLBACK=http://localhost:8080
